# OJ Engine 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# LLM 配置 (OpenAI API)
# ============================================

# OpenAI API Key (必填)
LLM_OPENAI_API_KEY=your-api-key-here

# OpenAI Base URL (可选,用于自定义 API 端点)
# LLM_OPENAI_BASE_URL=https://api.openai.com/v1

# Parser 节点使用的模型
LLM_PARSER_MODEL=gpt-4

# Generator 节点使用的模型
LLM_GENERATOR_MODEL=gpt-4

# Parser 温度参数 (0.0-1.0,越低越确定)
LLM_PARSER_TEMPERATURE=0.1

# Generator 温度参数 (0.0-1.0,越低越确定)
LLM_GENERATOR_TEMPERATURE=0.2

# ============================================
# Docker 沙箱配置
# ============================================

# 默认 Docker 镜像
DOCKER_DEFAULT_IMAGE=python:3.10-slim

# 默认内存限制
DOCKER_DEFAULT_MEM_LIMIT=512m

# 默认 CPU 配额 (微秒)
DOCKER_DEFAULT_CPU_QUOTA=50000

# 默认超时时间 (秒)
DOCKER_DEFAULT_TIMEOUT=30


